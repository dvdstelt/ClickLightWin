<Window x:Class="ClickLightWin.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClickLightWin"
        xmlns:views="clr-namespace:ClickLightWin.Views"
        Title="ClickLight Settings"
        Width="400"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#FFFFFF"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

  <Window.Resources>
    <SolidColorBrush x:Key="Accent" Color="#3B82F6" />
    <SolidColorBrush x:Key="Text" Color="#1F2933" />
    <SolidColorBrush x:Key="Muted" Color="#6B7280" />
    <SolidColorBrush x:Key="Segment" Color="#F1F3F5" />
    <SolidColorBrush x:Key="SegmentBorder" Color="#E3E6EA" />

    <!-- Segmented single-select control (used for size and duration presets) -->
    <Style x:Key="Segmented" TargetType="ListBox">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
      <Setter Property="ItemsPanel">
        <Setter.Value>
          <ItemsPanelTemplate>
            <UniformGrid Rows="1" />
          </ItemsPanelTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="ItemContainerStyle">
        <Setter.Value>
          <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                  <Border x:Name="seg" Background="{StaticResource Segment}"
                          BorderBrush="{StaticResource SegmentBorder}" BorderThickness="1"
                          CornerRadius="8" Margin="3,0" Padding="0,9">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="seg" Property="BorderBrush" Value="{StaticResource Accent}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                      <Setter TargetName="seg" Property="Background" Value="{StaticResource Accent}" />
                      <Setter TargetName="seg" Property="BorderBrush" Value="{StaticResource Accent}" />
                      <Setter Property="Foreground" Value="White" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="AccentButton" TargetType="Button">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource Accent}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8" Padding="20,8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Background" Value="#2F6FE0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Muted}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="2,0,0,6" />
    </Style>

    <!-- Compact color dropdown: a swatch + name per item -->
    <DataTemplate x:Key="ColorItem">
      <StackPanel Orientation="Horizontal">
        <Border Width="16" Height="16" CornerRadius="4" Background="{Binding Brush}"
                BorderBrush="{StaticResource SegmentBorder}" BorderThickness="1" VerticalAlignment="Center" />
        <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" Margin="8,0,0,0" VerticalAlignment="Center" />
      </StackPanel>
    </DataTemplate>

    <Style x:Key="ColorCombo" TargetType="ComboBox">
      <Setter Property="ItemsSource" Value="{x:Static local:Palette.Colors}" />
      <Setter Property="SelectedValuePath" Value="Hex" />
      <Setter Property="ItemTemplate" Value="{StaticResource ColorItem}" />
      <Setter Property="Width" Value="128" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- Small reset glyph button next to each shortcut -->
    <Style x:Key="ResetButton" TargetType="Button">
      <Setter Property="Content" Value="&#x21BA;" />
      <Setter Property="ToolTip" Value="Reset to default" />
      <Setter Property="Foreground" Value="{StaticResource Muted}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg" Background="Transparent" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Background" Value="#E3E6EA" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="KeyCap" TargetType="Border">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource SegmentBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Padding" Value="9,3" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Click-to-record shortcut field -->
    <Style TargetType="views:ShortcutRecorder">
      <Setter Property="Foreground" Value="{StaticResource Text}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="MinWidth" Value="128" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="views:ShortcutRecorder">
            <Border x:Name="box" Background="White" BorderBrush="{StaticResource SegmentBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="10,5">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}" />
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}" />
                <Setter TargetName="box" Property="Background" Value="#EAF1FE" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <SolidColorBrush x:Key="TrackOff" Color="#D1D5DB" />

    <!-- Pill toggle switch (templated CheckBox so IsChecked bindings are unchanged) -->
    <Style x:Key="ToggleSwitch" TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource Text}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <StackPanel Orientation="Horizontal" Background="Transparent">
              <Border x:Name="track" Width="42" Height="24" CornerRadius="12"
                      Background="{StaticResource TrackOff}" VerticalAlignment="Center">
                <Ellipse x:Name="thumb" Width="18" Height="18" Fill="White"
                         HorizontalAlignment="Left" Margin="3,0,0,0" />
              </Border>
              <ContentPresenter VerticalAlignment="Center" Margin="12,0,0,0" />
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="track" Property="Background" Value="{StaticResource Accent}" />
                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right" />
                <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <StackPanel Margin="24,22">
    <TextBlock Text="ClickLight" FontSize="21" FontWeight="SemiBold" Foreground="{StaticResource Text}" />
    <TextBlock Text="Highlight your mouse clicks on screen."
               Foreground="{StaticResource Muted}" Margin="0,2,0,20" />

    <TextBlock Text="PULSE SIZE" Style="{StaticResource SectionLabel}" />
    <ListBox Style="{StaticResource Segmented}"
             ItemsSource="{x:Static local:Presets.Sizes}"
             DisplayMemberPath="Title" SelectedValuePath="Value"
             SelectedValue="{Binding BaseDiameterDips, Mode=TwoWay}"
             Margin="0,0,0,20" />

    <TextBlock Text="PULSE DURATION" Style="{StaticResource SectionLabel}" />
    <ListBox Style="{StaticResource Segmented}"
             ItemsSource="{x:Static local:Presets.Durations}"
             DisplayMemberPath="Title" SelectedValuePath="Value"
             SelectedValue="{Binding PulseDurationMs, Mode=TwoWay}"
             Margin="0,0,0,20" />

    <TextBlock Text="COLORS" Style="{StaticResource SectionLabel}" />
    <Grid Margin="0,0,0,20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Left click" Foreground="{StaticResource Text}" VerticalAlignment="Center" Margin="0,0,0,6" />
      <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource ColorCombo}" SelectedValue="{Binding LeftColorHex, Mode=TwoWay}" Margin="0,0,0,6" />
      <TextBlock Grid.Row="1" Grid.Column="0" Text="Right click" Foreground="{StaticResource Text}" VerticalAlignment="Center" Margin="0,0,0,6" />
      <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource ColorCombo}" SelectedValue="{Binding RightColorHex, Mode=TwoWay}" Margin="0,0,0,6" />
      <TextBlock Grid.Row="2" Grid.Column="0" Text="Middle click" Foreground="{StaticResource Text}" VerticalAlignment="Center" Margin="0,0,0,6" />
      <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource ColorCombo}" SelectedValue="{Binding MiddleColorHex, Mode=TwoWay}" Margin="0,0,0,6" />
      <TextBlock Grid.Row="3" Grid.Column="0" Text="Annotations" Foreground="{StaticResource Text}" VerticalAlignment="Center" />
      <ComboBox Grid.Row="3" Grid.Column="1" Style="{StaticResource ColorCombo}" SelectedValue="{Binding AnnotationColorHex, Mode=TwoWay}" />
    </Grid>

    <CheckBox Content="Show drag trail" IsChecked="{Binding ShowDrag}"
              Style="{StaticResource ToggleSwitch}" Margin="2,0,0,14" />

    <CheckBox Content="Show release ring (on hold + release)" IsChecked="{Binding ShowRelease}"
              Style="{StaticResource ToggleSwitch}" Margin="2,0,0,14" />

    <CheckBox Content="Laser pointer (glowing cursor + drag stroke)" IsChecked="{Binding ShowLaserPointer}"
              Style="{StaticResource ToggleSwitch}" Margin="2,0,0,14" />

    <CheckBox Content="Annotations (Ctrl+Shift + drag)" IsChecked="{Binding EnableAnnotations}"
              Style="{StaticResource ToggleSwitch}" Margin="2,0,0,14" />

    <CheckBox Content="Show keyboard shortcuts (modifier combos only)" IsChecked="{Binding ShowShortcuts}"
              Style="{StaticResource ToggleSwitch}" Margin="2,0,0,20" />

    <Border Background="{StaticResource Segment}" CornerRadius="8" Padding="14,12" Margin="0,0,0,20">
      <StackPanel>
        <TextBlock Text="SHORTCUTS" Style="{StaticResource SectionLabel}" Margin="0,0,0,8" />
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Toggle ClickLight" Foreground="{StaticResource Text}"
                     VerticalAlignment="Center" Margin="0,0,0,6" />
          <views:ShortcutRecorder Grid.Row="0" Grid.Column="1" Binding="{Binding ToggleHotKey, Mode=TwoWay}" Margin="0,0,0,6" />
          <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource ResetButton}" Tag="toggle" Click="OnResetShortcut" Margin="4,0,0,6" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Clear annotations" Foreground="{StaticResource Text}"
                     VerticalAlignment="Center" Margin="0,0,0,6" />
          <views:ShortcutRecorder Grid.Row="1" Grid.Column="1" Binding="{Binding ClearHotKey, Mode=TwoWay}" Margin="0,0,0,6" />
          <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource ResetButton}" Tag="clear" Click="OnResetShortcut" Margin="4,0,0,6" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Drawing mode" Foreground="{StaticResource Text}"
                     VerticalAlignment="Center" />
          <views:ShortcutRecorder Grid.Row="2" Grid.Column="1" Binding="{Binding DrawModeHotKey, Mode=TwoWay}" />
          <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource ResetButton}" Tag="draw" Click="OnResetShortcut" Margin="4,0,0,0" />
        </Grid>
        <TextBlock Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"
                   Text="Click a field and press a new combination (needs Ctrl, Alt or Win). Esc cancels." />
        <TextBlock Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"
                   Text="Fixed gestures: Ctrl+Shift + left-drag = arrow, right-drag = box" />
      </StackPanel>
    </Border>

    <Button Content="Close" Style="{StaticResource AccentButton}"
            HorizontalAlignment="Right" IsCancel="True" Click="OnCloseClick" />
  </StackPanel>
</Window>
